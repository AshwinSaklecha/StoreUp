# StoreUp environment configuration
# Copy this file to `.env` and fill in the real key you receive at the hackathon.

# Your Gemini API key (get it at the hackathon on July 11).
GEMINI_API_KEY=your_key_here

# Live voice+camera model. MUST be a Live-capable model.
LIVE_MODEL=gemini-3.1-flash-live-preview

# Managed Agent (Interactions API). Verify at hackathon; falls back safely.
AGENT_ID=antigravity-preview-05-2026

# Fallback model for Beckn JSON if the Managed Agent is unavailable.
AGENT_MODEL=gemini-3.5-flash

# How the Beckn catalog is built on publish. "deterministic" = instant + always
# valid (use for the live demo). Set to "auto" to showcase the Managed Agent path.
BECKN_MODE=deterministic

# Nano Banana 2 Lite product images for the buyer app (background, emoji fallback).
IMAGE_MODEL=gemini-3.1-flash-lite-image
ENABLE_PRODUCT_IMAGES=true
